generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  nom       String
  createdAt DateTime @default(now())
}

model Formation {
  id          String   @id @default(cuid())
  titre       String
  slug        String   @unique
  niveau      Niveau
  domaine     String
  description String
  programme   String
  prerequis   String?
  debouches   String?
  formateur   String
  duree       String
  prix        Float
  image       String?
  publie      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Annonce {
  id        String         @id @default(cuid())
  titre     String
  slug      String         @unique
  contenu   String
  extrait   String
  categorie CategorieAnnonce
  image     String?
  statut    Statut         @default(BROUILLON)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  nom       String
  email     String
  sujet     String
  message   String
  lu        Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Inscription {
  id         String   @id @default(cuid())
  nom        String
  prenom     String
  email      String
  telephone  String?
  formation  String
  niveau     String
  message    String?
  traite     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Media {
  id          String        @id @default(cuid())
  titre       String
  description String?
  url         String
  type        MediaType
  categorie   CategorieMedia
  publie      Boolean       @default(true)
  ordre       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum Niveau {
  DEBUTANT
  ELEMENTAIRE
  INTERMEDIAIRE
  AVANCE
  EXPERT
}

enum Statut {
  BROUILLON
  PUBLIE
}

enum CategorieAnnonce {
  ACTUALITE
  EVENEMENT
  OFFRE
  RESULTAT
  AUTRE
}

model Recruteur {
  id          String   @id @default(cuid())
  nom         String
  entreprise  String
  role        String
  email       String
  message     String
  lu          Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum MediaType {
  PHOTO
  VIDEO
}

enum CategorieMedia {
  COURS
  EVENEMENT
  EXAMENS
  VIE_CAMPUS
  ALLEMAGNE
  AUTRE
}
